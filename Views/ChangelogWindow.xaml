<Window x:Class="InwentaryzacjaSprzetu.Views.ChangelogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historia wersji"
        Width="640" Height="720"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <Border Grid.Row="0" Background="#1E3A5F" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📋" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Historia wersji" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Inwentaryzacja Sprzętu — Merkury Market"
                               FontSize="11" Foreground="#FFAAC8E8"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Lista zmian -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Entries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="16,14">
                            <StackPanel>

                                <!-- Wersja + data + badge -->
                                <DockPanel Margin="0,0,0,8">
                                    <!-- Badge z numerem wersji -->
                                    <Border DockPanel.Dock="Left" CornerRadius="4" Padding="8,3"
                                            Margin="0,0,10,0" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8E8E8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLatest}" Value="True">
                                                        <Setter Property="Background" Value="#1E3A5F"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Version}" FontWeight="Bold" FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#444444"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLatest}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Data -->
                                    <TextBlock DockPanel.Dock="Left" Text="{Binding Date}"
                                               Foreground="#666" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>

                                    <!-- Znacznik AKTUALNA -->
                                    <Border DockPanel.Dock="Left"
                                            Visibility="{Binding IsLatest, Converter={StaticResource BoolToVis}}"
                                            Background="#27AE60" CornerRadius="3" Padding="5,2"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="AKTUALNA" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>

                                    <UIElement/>
                                </DockPanel>

                                <!-- Lista zmian -->
                                <ItemsControl ItemsSource="{Binding Changes}" Margin="4,0,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,2">
                                                <TextBlock DockPanel.Dock="Left" Text="•" Margin="0,0,8,0"
                                                           Foreground="#555" VerticalAlignment="Top"
                                                           FontSize="12"/>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                                           Foreground="#333" FontSize="12"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Dolny pasek -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#DDDDDD"
                BorderThickness="0,1,0,0" Padding="16,10">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Zamknij" Width="90" Height="28"
                        Click="CloseButton_Click" IsDefault="True"/>
                <CheckBox Content="Nie pokazuj przy uruchomieniu do następnej aktualizacji"
                          IsChecked="{Binding DontShowAgain, Mode=TwoWay}"
                          VerticalAlignment="Center" FontSize="12" Margin="0,0,12,0"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
