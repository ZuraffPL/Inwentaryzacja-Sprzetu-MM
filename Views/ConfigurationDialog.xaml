<Window x:Class="InwentaryzacjaSprzetu.Views.ConfigurationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Konfiguracja"
        Width="420" Height="230"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <Border Grid.Row="0" Background="#1E3A5F" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚙️" FontSize="24" FontFamily="Segoe UI Emoji"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Konfiguracja" FontSize="16" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Zawartość -->
        <StackPanel Grid.Row="1" Margin="20,16,20,12">

            <!-- Autostart -->
            <Border Background="#F5F9FF" BorderBrush="#C0D8F0" BorderThickness="1"
                    CornerRadius="4" Padding="14,12" Margin="0,0,0,10">
                <StackPanel>
                    <CheckBox x:Name="RunOnStartupCheckBox"
                              Content="Uruchamiaj aplikację przy starcie systemu Windows"
                              FontSize="13"
                              IsChecked="{Binding RunOnStartup, Mode=TwoWay}"/>
                    <TextBlock Text="Aplikacja będzie uruchamiana automatycznie i minimalizowana do traya."
                               FontSize="11" Foreground="#666" TextWrapping="Wrap"
                               Margin="20,5,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- Przyciski -->
        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="12,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Width="80" Height="28" Margin="0,0,8,0"
                        IsDefault="True" Click="OkButton_Click"/>
                <Button Content="Anuluj" Width="80" Height="28"
                        IsCancel="True" Click="CancelButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
