<Window x:Class="InwentaryzacjaSprzetu.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="O programie"
        Width="400" Height="390"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <Border Grid.Row="0" Background="#1E3A5F" Padding="20,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📦" FontSize="36" FontFamily="Segoe UI Emoji"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Inwentaryzacja Sprzętu"
                               FontSize="17" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="dla Merkury Market"
                               FontSize="11" Foreground="#FFAAC8E8" Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Treść -->
        <StackPanel Grid.Row="1" Margin="24,18,24,12">

            <!-- Wersja -->
            <Border Background="#EEF6FF" BorderBrush="#AAD4FF" BorderThickness="3,0,0,0"
                    CornerRadius="0,4,4,0" Padding="12,10" Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Wersja:" FontSize="12" Foreground="#555"
                               VerticalAlignment="Center" Width="70"/>
                    <TextBlock x:Name="VersionLabel" FontSize="14" FontWeight="Bold"
                               Foreground="#1E3A5F" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Opis -->
            <TextBlock Text="Aplikacja do zarządzania sprzętem komputerowym&#x0a;i teleinformatycznym w sieci sklepów."
                       FontSize="12" Foreground="#333" TextWrapping="Wrap"
                       LineHeight="20" Margin="0,0,0,14"/>

            <!-- Siatka informacji -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Autor:" FontSize="11"
                           Foreground="#777" Margin="0,3"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Marcin Żurawicz" FontSize="11"
                           Foreground="#333" FontWeight="SemiBold" Margin="0,3"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Prawa:" FontSize="11"
                           Foreground="#777" Margin="0,3"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="© 2025–2026" FontSize="11"
                           Foreground="#333" Margin="0,3"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Technologie:" FontSize="11"
                           Foreground="#777" Margin="0,3"/>
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Text=".NET 10 · WPF · Entity Framework Core 10 · SQLite · CommunityToolkit.Mvvm · QuestPDF"
                           FontSize="11" Foreground="#333" TextWrapping="Wrap" Margin="0,3"/>
            </Grid>
        </StackPanel>

        <!-- Stopka -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#DDDDDD"
                BorderThickness="0,1,0,0" Padding="16,10">
            <Button Content="OK" Width="80" Height="28" HorizontalAlignment="Right"
                    Click="OkButton_Click" IsDefault="True"/>
        </Border>
    </Grid>
</Window>