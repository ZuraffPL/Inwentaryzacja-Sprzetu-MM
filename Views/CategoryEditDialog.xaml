<Window x:Class="InwentaryzacjaSprzetu.Views.CategoryEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Edycja Kategorii" Height="400" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <TextBlock Grid.Row="0" Text="Edycja kategorii" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Formularz -->
        <StackPanel Grid.Row="1">
            <!-- Kod kategorii -->
            <Label Content="Kod kategorii:" FontWeight="Bold"/>
            <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15" MaxLength="10"
                     ToolTip="Krótki kod używany w numeracji sprzętu (np. 'COMP', 'PRIN')"/>
            
            <!-- Nazwa kategorii -->
            <Label Content="Nazwa kategorii:" FontWeight="Bold"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15"/>
            
            <!-- Opis -->
            <Label Content="Opis:" FontWeight="Bold"/>
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Height="60" Margin="0,0,0,15"/>
            
            <!-- Komunikat walidacji -->
            <TextBlock Text="{Binding ValidationMessage}" Foreground="Red" 
                       Margin="0,0,0,10"/>
        </StackPanel>

        <!-- Przyciski -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Zapisz" Width="80" Height="30" Margin="0,0,10,0" 
                    Command="{Binding SaveCommand}" IsDefault="True"/>
            <Button Content="Anuluj" Width="80" Height="30" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>