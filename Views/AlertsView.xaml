<UserControl x:Class="InwentaryzacjaSprzetu.Views.AlertsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Styl wiersza DataGrid: kolory wg IsTriggered + selekcja -->
        <Style x:Key="AlertRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTriggered}" Value="True">
                    <Setter Property="Background" Value="#FFF3CD"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#5B9BD5"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8F8F8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ArchivedRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#777"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#5B9BD5"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Pasek narzędzi -->
            <RowDefinition Height="Auto"/>  <!-- Nagłówek aktywnych -->
            <RowDefinition Height="*"/>     <!-- DataGrid aktywnych -->
            <RowDefinition Height="Auto"/>  <!-- Expander archiwum -->
        </Grid.RowDefinitions>

        <!-- ═══ PASEK NARZĘDZI ══════════════════════════════════════════════ -->
        <ToolBar Grid.Row="0" Background="#F5F5F5">
            <Button ToolTip="Dodaj nowe powiadomienie"
                    Command="{Binding DataContext.AddAlertCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="➕" Margin="0,0,5,0"/>
                    <TextBlock Text="Dodaj powiadomienie"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button ToolTip="Edytuj zaznaczone powiadomienie"
                    Command="{Binding DataContext.EditAlertCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✏️" Margin="0,0,5,0"/>
                    <TextBlock Text="Edytuj"/>
                </StackPanel>
            </Button>
            <Button ToolTip="Archiwizuj zaznaczone powiadomienie (oznacz jako zakończone)"
                    Command="{Binding DataContext.ArchiveAlertCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📁" Margin="0,0,5,0"/>
                    <TextBlock Text="Archiwizuj"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button ToolTip="Usuń zaznaczone powiadomienie"
                    Command="{Binding DataContext.DeleteAlertCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Background="#FFE8E8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🗑️" Margin="0,0,5,0"/>
                    <TextBlock Text="Usuń"/>
                </StackPanel>
            </Button>
        </ToolBar>

        <!-- ═══ NAGŁÓWEK AKTYWNYCH ══════════════════════════════════════════ -->
        <Border Grid.Row="1" Padding="12,7" Margin="0,0,0,1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#E8F5E9"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.HasTriggeredAlerts, RelativeSource={RelativeSource AncestorType=Window}}"
                                     Value="True">
                            <Setter Property="Background" Value="#FFF9E6"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔔" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock FontWeight="Bold" VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Powiadomienia — aktywne: {0}, wyzwolone: {1}">
                            <Binding Path="DataContext.ActiveAlerts.Count" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="DataContext.TriggeredAlertCount" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <TextBlock Margin="16,0,0,0" Foreground="#777" VerticalAlignment="Center"
                           Text="(żółte wiersze = powiadomienia, których data wyzwolenia już minęła)"/>
            </StackPanel>
        </Border>

        <!-- ═══ DATAGRID AKTYWNYCH ══════════════════════════════════════════ -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding DataContext.ActiveAlerts, RelativeSource={RelativeSource AncestorType=Window}}"
                  SelectedItem="{Binding DataContext.SelectedAlert, RelativeSource={RelativeSource AncestorType=Window}}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  AlternationCount="2"
                  RowStyle="{StaticResource AlertRowStyle}"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#D0D0D0" BorderThickness="0,1,0,0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Status"
                                    Binding="{Binding StatusLabel}"
                                    Width="130"/>
                <DataGridTextColumn Header="Nazwa"
                                    Binding="{Binding Name}"
                                    Width="180"/>
                <DataGridTextColumn Header="Dotyczy"
                                    Binding="{Binding TargetDescription}"
                                    Width="220"/>
                <DataGridTextColumn Header="Data wyzwolenia"
                                    Binding="{Binding TriggerDate, StringFormat=dd.MM.yyyy}"
                                    Width="120"/>
                <DataGridTextColumn Header="Treść powiadomienia"
                                    Binding="{Binding Content}"
                                    Width="*"/>
                <DataGridTextColumn Header="Opis"
                                    Binding="{Binding Description}"
                                    Width="140"/>
            </DataGrid.Columns>

            <!-- Puste zaznaczenie gdy kliknie poza wierszami -->
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftClick"
                              Command="{Binding DataContext.ClearAlertSelectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </DataGrid.InputBindings>
        </DataGrid>

        <!-- ═══ EXPANDER ARCHIWUM ════════════════════════════════════════════ -->
        <Expander Grid.Row="3" Header="📁  Archiwum powiadomień" IsExpanded="False"
                  Margin="0,4,0,0" Padding="0,4,0,0">
            <DataGrid
                  ItemsSource="{Binding DataContext.ArchivedAlerts, RelativeSource={RelativeSource AncestorType=Window}}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  AlternationCount="2"
                  RowStyle="{StaticResource ArchivedRowStyle}"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  MaxHeight="220"
                  BorderBrush="#D0D0D0" BorderThickness="1">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nazwa"
                                        Binding="{Binding Name}"
                                        Width="180"/>
                    <DataGridTextColumn Header="Dotyczy"
                                        Binding="{Binding TargetDescription}"
                                        Width="220"/>
                    <DataGridTextColumn Header="Data wyzwolenia"
                                        Binding="{Binding TriggerDate, StringFormat=dd.MM.yyyy}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Treść"
                                        Binding="{Binding Content}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Zarchiwizowano"
                                        Binding="{Binding ArchivedDate, StringFormat=dd.MM.yyyy}"
                                        Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Expander>
    </Grid>
</UserControl>
