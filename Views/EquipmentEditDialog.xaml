<Window x:Class="InwentaryzacjaSprzetu.Views.EquipmentEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:InwentaryzacjaSprzetu.Models"
        xmlns:helpers="clr-namespace:InwentaryzacjaSprzetu.Helpers"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}" Height="910" Width="950"
        MinHeight="850" MinWidth="860"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <helpers:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        
        <!-- Style dla ComboBox z wyróżnieniem wybranej pozycji -->
        <Style x:Key="HighlightedComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="IsEditable" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Trigger>
                <Trigger Property="HasItems" Value="True">
                    <Setter Property="Background" Value="#F0F8F0"/>
                </Trigger>
                <Trigger Property="SelectedItem" Value="{x:Null}">
                    <Setter Property="Background" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Style dla elementów ComboBox -->
        <Style x:Key="ComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="5,3"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4CAF50"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#81C784"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Konwerter do odwracania bool dla Visibility -->
        <Style x:Key="InverseBoolToVisibilityConverter" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <!-- Konwerter dla tła pola tylko do odczytu -->
        <Style x:Key="ReadOnlyTextBoxStyle" TargetType="TextBox">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="Background" Value="LightGray"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <TextBlock Grid.Row="0" Text="{Binding DialogTitle}" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- Formularz – dwukolumnowy Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel>

        <!-- === Sekcja: Kopiuj dane z istniejącego sprzętu (tylko przy dodawaniu) === -->
        <Border Margin="0,0,0,10" Padding="10,8"
                Background="#EEF6FF" BorderBrush="#90CAF9" BorderThickness="1"
                CornerRadius="4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditMode}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#x1F4CB; Skopiuj dane z:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding EquipmentTemplates}"
                          SelectedItem="{Binding SelectedEquipmentTemplate}"
                          DisplayMemberPath="InventoryNumber"
                          TextSearch.TextPath="InventoryNumber"
                          IsEditable="True"
                          ToolTip="Wybierz sprzęt z tej samej kategorii — automatycznie uzupełni Nazwę oraz dane techniczne (Marka/System, Model/RAM, Nr seryjny/Procesor)"/>
                <Button Grid.Column="2" Content="Wyczyść" Margin="8,0,0,0" Padding="8,3"
                        ToolTip="Wyczyść wybór szablonu"
                        Click="ClearTemplateButton_Click"/>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0: Lokalizacja | Kategoria -->
                <RowDefinition Height="Auto"/>  <!-- 1: Nr sprzętu | Nr inwentarzowy -->
                <RowDefinition Height="Auto"/>  <!-- 2: Nazwa (pełna szerokość) -->
                <RowDefinition Height="Auto"/>  <!-- 3: Marka/System | Model/RAM -->
                <RowDefinition Height="Auto"/>  <!-- 4: Nr seryjny/Procesor | Adres IP (wark.) -->
                <RowDefinition Height="Auto"/>  <!-- 5: Do komputera (pełna szer., wark.) -->
                <RowDefinition Height="Auto"/>  <!-- 6: Dział | Gdzie? -->
                <RowDefinition Height="Auto"/>  <!-- 7: Custom Dept (pełna szer., wark.) -->
                <RowDefinition Height="Auto"/>  <!-- 8: Cena/DataZak | Gwarancja/Status -->
                <RowDefinition Height="Auto"/>  <!-- 9: Opis | Notatki -->
                <RowDefinition Height="Auto"/>  <!-- 10: Komunikat walidacji -->
            </Grid.RowDefinitions>

            <!-- === Wiersz 0: Lokalizacja | Kategoria === -->
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                <Label Content="Lokalizacja:" FontWeight="Bold" Padding="0,0,0,2"/>
                <ComboBox ItemsSource="{Binding Locations}"
                          SelectedItem="{Binding SelectedLocation}"
                          DisplayMemberPath="Name"
                          TextSearch.TextPath="Name"
                          Style="{StaticResource HighlightedComboBoxStyle}"
                          ItemContainerStyle="{StaticResource ComboBoxItemStyle}"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                <Label Content="Kategoria:" FontWeight="Bold" Padding="0,0,0,2"/>
                <ComboBox ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          DisplayMemberPath="Name"
                          TextSearch.TextPath="Name"
                          Style="{StaticResource HighlightedComboBoxStyle}"
                          ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                          Height="25"/>
            </StackPanel>

            <!-- === Wiersz 1: Nr sprzętu | Nr inwentarzowy === -->
            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                <Label Content="Numer sprzętu:" FontWeight="Bold" Padding="0,0,0,2"/>
                <TextBox Text="{Binding EquipmentNumber, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsEquipmentNumberEditable}"/>
                <TextBlock Text="Wprowadź numer sprzętu (np. 12). Numer inwentarzowy zostanie wygenerowany automatycznie."
                           Style="{StaticResource InverseBoolToVisibilityConverter}"
                           FontStyle="Italic" FontSize="11" Foreground="Gray"
                           TextWrapping="Wrap" Margin="0,3,0,0"/>
                <CheckBox Content="Brak nr inwentarzowego"
                          IsChecked="{Binding NoInventoryNumber}"
                          ToolTip="Zaznacz, gdy nr inwentarzowy jest nieczytelny lub sprzęt go nie posiada w danej chwili"
                          Margin="0,8,0,0" FontWeight="SemiBold"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8">
                <Label Content="Numer inwentarzowy (wygenerowany):" FontWeight="Bold" Padding="0,0,0,2"/>
                <TextBox Text="{Binding InventoryNumber, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True"
                         Style="{StaticResource ReadOnlyTextBoxStyle}"/>
                <Border Background="#FFF3E2" BorderBrush="#E65100" BorderThickness="1"
                        CornerRadius="3" Padding="6,4" Margin="0,4,0,0"
                        Visibility="{Binding NoInventoryNumber, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="⚠️ Sprzęt bez nr inwentarzowego — nadaj go później przez zdarzenie 'Nadanie nr inwentarzowego'."
                               Foreground="#E65100" FontStyle="Italic" FontSize="11"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>

            <!-- === Wiersz 2: Nazwa sprzętu (pełna szerokość) === -->
            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,8">
                <Label Content="Nazwa sprzętu:" FontWeight="Bold" Padding="0,0,0,2"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <!-- === Wiersz 3: Marka/System | Model/RAM === -->
            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,8">
                <Label Content="{Binding BrandLabel}" FontWeight="Bold" Padding="0,0,0,2"/>
                <TextBox Text="{Binding Brand, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,8">
                <Label Content="{Binding ModelLabel}" FontWeight="Bold" Padding="0,0,0,2"/>
                <TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <!-- === Wiersz 4: Nr seryjny/Procesor | Adres IP (warunkowy) === -->
            <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,8">
                <Label Content="{Binding SerialNumberLabel}" FontWeight="Bold" Padding="0,0,0,2"/>
                <TextBox Text="{Binding SerialNumber, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,0,0,8"
                        Visibility="{Binding IsNoIpCategory, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <Label Content="Adres IP:" FontWeight="Bold" Padding="0,0,0,2"/>
                <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="np. 192.168.1.10"/>
            </StackPanel>

            <!-- === Wiersz 5: Do komputera/serwera (pełna szerokość, warunkowy) === -->
            <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,8"
                        Visibility="{Binding IsConnectedToComputerCategory, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Label Content="Do jakiego komputera / serwera:" FontWeight="Bold" Padding="0,0,0,2"/>
                <ComboBox SelectedItem="{Binding SelectedConnectedEquipment}"
                          ItemsSource="{Binding Computers}"
                          DisplayMemberPath="InventoryNumber"
                          TextSearch.TextPath="InventoryNumber"/>
            </StackPanel>

            <!-- === Wiersz 6: Dział | Gdzie? === -->
            <StackPanel Grid.Row="6" Grid.Column="0" Margin="0,0,0,4">
                <Label Content="Dział:" FontWeight="Bold" Padding="0,0,0,2"/>
                <ComboBox x:Name="DepartmentComboBox"
                          SelectedItem="{Binding SelectedDepartment}"
                          ItemsSource="{Binding DepartmentOptions}"
                          DisplayMemberPath="Name"
                          TextSearch.TextPath="Name"
                          SelectionChanged="DepartmentComboBox_SelectionChanged"
                          Style="{StaticResource HighlightedComboBoxStyle}"
                          ItemContainerStyle="{StaticResource ComboBoxItemStyle}"/>
            </StackPanel>
            <StackPanel Grid.Row="6" Grid.Column="2" Margin="0,0,0,8">
                <Label Content="Gdzie?" FontWeight="Bold" Padding="0,0,0,2"/>
                <TextBox Text="{Binding LocationDetails, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="np. 'obok okna', 'przy drzwiach', etc."/>
            </StackPanel>

            <!-- === Wiersz 7: Custom Department (warunkowy, pełna szerokość) === -->
            <TextBox x:Name="CustomDepartmentTextBox"
                     Grid.Row="7" Grid.Column="0"
                     Text="{Binding CustomDepartmentName}"
                     Visibility="Collapsed"
                     Margin="0,0,0,8"/>

            <!-- === Wiersz 8: Cena zakupu + Data zakupu | Gwarancja do + Status === -->
            <StackPanel Grid.Row="8" Grid.Column="0" Margin="0,0,0,8">
                <Label Content="Cena zakupu:" FontWeight="Bold" Padding="0,0,0,2"/>
                <TextBox Text="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                         Margin="0,0,0,6"/>
                <Label Content="Data zakupu:" FontWeight="Bold" Padding="0,0,0,2"/>
                <DatePicker SelectedDate="{Binding PurchaseDate}"/>
            </StackPanel>
            <StackPanel Grid.Row="8" Grid.Column="2" Margin="0,0,0,8">
                <Label Content="Gwarancja do:" FontWeight="Bold" Padding="0,0,0,2"/>
                <DatePicker SelectedDate="{Binding WarrantyEndDate}" Margin="0,0,0,6"/>
                <Label Content="Status:" FontWeight="Bold" Padding="0,0,0,2"/>
                <ComboBox SelectedValue="{Binding Status}"
                          SelectedValuePath="Tag"
                          Style="{StaticResource HighlightedComboBoxStyle}"
                          ItemContainerStyle="{StaticResource ComboBoxItemStyle}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Content}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                    <ComboBox.Items>
                        <ComboBoxItem Content="Sprawny" Tag="Active"/>
                        <ComboBoxItem Content="Rezerwa" Tag="Inactive"/>
                        <ComboBoxItem Content="W konserwacji" Tag="UnderMaintenance"/>
                        <ComboBoxItem Content="Zepsuty (uszkodzony)" Tag="Damaged"/>
                        <ComboBoxItem Content="Zutylizowany (kasacja)" Tag="Disposed"/>
                    </ComboBox.Items>
                </ComboBox>
            </StackPanel>

            <!-- === Wiersz 9: Opis | Notatki === -->
            <StackPanel Grid.Row="9" Grid.Column="0" Margin="0,0,0,8">
                <Label Content="Opis:" FontWeight="Bold" Padding="0,0,0,2"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="55" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>
            <StackPanel Grid.Row="9" Grid.Column="2" Margin="0,0,0,8">
                <Label Content="Notatki:" FontWeight="Bold" Padding="0,0,0,2"/>
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="55" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>

            <!-- === Wiersz 10: Komunikat walidacji === -->
            <TextBlock Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="3"
                       Text="{Binding ValidationMessage}" Foreground="Red"
                       Margin="0,2,0,0" TextWrapping="Wrap"/>
        </Grid>
        </StackPanel>
        </ScrollViewer>

        <!-- Przyciski -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Zapisz" Width="90" Height="30" Margin="0,0,10,0"
                    Command="{Binding SaveCommand}" IsDefault="True"/>
            <Button Content="Anuluj" Width="90" Height="30" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>