<Window x:Class="InwentaryzacjaSprzetu.Views.UserManualWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Instrukcja obsługi — Inwentaryzacja Sprzętu"
        Width="860" Height="620"
        MinWidth="640" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Styl przycisku nawigacyjnego -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#CCDDEE"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2E5F8A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A7AB0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Styl nagłówka sekcji -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E3A5F"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Styl nagłówka podsekcji -->
        <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2E5F8A"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>

        <!-- Styl akapitu -->
        <Style x:Key="ParaStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>

        <!-- Styl listy wypunktowanej -->
        <Style x:Key="BulletStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="16,2,0,2"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>

        <!-- Styl notatki / podpowiedzi -->
        <Style x:Key="TipStyle" TargetType="Border">
            <Setter Property="Background" Value="#EEF6FF"/>
            <Setter Property="BorderBrush" Value="#AAD4FF"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="CornerRadius" Value="0,4,4,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="195"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel nawigacji (lewy) -->
        <Grid Grid.Column="0" Background="#1E3A5F">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Logo nagłówka -->
            <Border Grid.Row="0" Padding="12,14,12,10" BorderBrush="#2E5F8A" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="📖" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Instrukcja obsługi" FontSize="12" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Przyciski sekcji -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,8,0,8">
                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_intro">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" Margin="0,0,8,0"/>
                            <TextBlock Text="Wstęp"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_equipment">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" Margin="0,0,8,0"/>
                            <TextBlock Text="Widok sprzętu"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_add">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,8,0"/>
                            <TextBlock Text="Dodawanie sprzętu"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_edit">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏️" Margin="0,0,8,0"/>
                            <TextBlock Text="Edycja i usuwanie"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_invnum">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔢" Margin="0,0,8,0"/>
                            <TextBlock Text="Nr inwentarzowy"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_colors">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎨" Margin="0,0,8,0"/>
                            <TextBlock Text="Kolory i statusy"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_filters">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔎" Margin="0,0,8,0"/>
                            <TextBlock Text="Filtry i eksport PDF"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_search">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Margin="0,0,8,0"/>
                            <TextBlock Text="Wyszukiwanie"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_events">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Margin="0,0,8,0"/>
                            <TextBlock Text="Zdarzenia"/>
                        </StackPanel>
                    </Button>                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_attachments">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4CE;" Margin="0,0,8,0"/>
                            <TextBlock Text="Za&#x142;&#x105;czniki"/>
                        </StackPanel>
                    </Button>                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_locations">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏪" Margin="0,0,8,0"/>
                            <TextBlock Text="Pawilony"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_categories">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📂" Margin="0,0,8,0"/>
                            <TextBlock Text="Kategorie i działy"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_alerts">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔔" Margin="0,0,8,0"/>
                            <TextBlock Text="Powiadomienia"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_csv">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" Margin="0,0,8,0"/>
                            <TextBlock Text="Eksport / Import CSV"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="sec_backup">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" Margin="0,0,8,0"/>
                            <TextBlock Text="Kopia zapasowa"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Treść podręcznika (prawa kolumna) -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="ContentScroll" Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          Padding="24,20,24,20">
                <StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- WSTĘP -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_intro" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="🏠  Wstęp"/>
                        <Separator Margin="0,0,0,10"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Inwentaryzacja Sprzętu to aplikacja desktopowa przeznaczona do zarządzania bazą sprzętu komputerowego i teleinformatycznego rozmieszczonego w pawilonach sieci Merkury Market."/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Aplikacja umożliwia: przeglądanie, dodawanie, edycję i usuwanie rekordów sprzętowych, prowadzenie historii zdarzeń dla każdego urządzenia oraz wykonywanie kopii zapasowej bazy danych."/>
                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="💡  Wszystkie dane przechowywane są lokalnie w pliku SQLite (inventory.db). Regularnie wykonuj kopię zapasową przez menu Narzędzia → Eksportuj bazę danych."/>
                        </Border>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- WIDOK SPRZĘTU -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_equipment" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="📦  Widok sprzętu"/>
                        <Separator Margin="0,0,0,10"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Widok sprzętu jest głównym ekranem aplikacji. Sprzęt wyświetlany jest w grupach wg kategorii, a w obrębie kategorii — posortowany wg numeru inwentarzowego."/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Pasek zakładek krajów"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Nad listą sprzętu znajdują się zakładki filtrowania wg kraju lokalizacji (np. PL, SK, CZ). Kliknięcie zakładki ogranicza widok do sprzętu z danego kraju. Zakładki można ukrywać prawym przyciskiem myszy."/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Grupy kategorii"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Każda kategoria sprzętu wyświetlana jest jako zwijana sekcja. Przycisk Zwiń wszystkie / Rozwiń wszystkie w pasku narzędzi steruje wszystkimi sekcjami jednocześnie."/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Pasek stanu"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Na dole okna widoczne są liczniki: łączna liczba sprzętu, ilość w rezerwie (dział REZ) oraz rozbicie wg statusów (Sprawny, Rezerwa, Konserwacja, Zepsuty, Kasacja)."/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Etykiety kolumn specyficzne dla kategorii"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Kolumna Marka, Model i Nr Seryjny wyświetlana jest pod inną nazwą w zależności od kategorii sprzętu:"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Komputery  —  System | RAM | Procesor"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Monitory  —  Marka | Model | Przekątna"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Kasy Fiskalne  —  Marka | Model | Nr unikatowy"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Pozostałe kategorie  —  Marka | Model | Nr Seryjny"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="W belce nagłówka grupy widoczne są nazwy kolumn właściwe dla danej kategorii. W oknie edycji sprzętu etykiety pól zmieniają się analogicznie."/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Zdarzenia przypisane do sprzętu"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Kliknięcie prawym przyciskiem myszy na wybrany sprzęt otwiera menu kontekstowe z opcją Pokaż zdarzenia. Wyświetla się wtędy lista zdarzeń tylko dla tego konkretnego urządzenia."/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Sprzęt podpięty do komputera"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Kliknięcie prawym przyciskiem myszy na komputer lub serwer i wybranie opcji Pokaż podłączony sprzęt wyświetla listę urządzeń powiązanych z danym komputerem (np. monitor, drukarka, UPS)."/>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- DODAWANIE SPRZĘTU -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_add" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="➕  Dodawanie sprzętu"/>
                        <Separator Margin="0,0,0,10"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Nowy sprzęt można dodać:"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Przyciskiem Nowy sprzęt na pasku narzędzi lub w menu Plik → Nowy sprzęt"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Prawym kliknięciem na kategorię w widoku sprzętu → Dodaj sprzęt w tej kategorii"/>
                        <TextBlock Margin="0,10,0,6" Style="{StaticResource SubHeaderStyle}" Text="Kopiowanie z istniejącego sprzętu"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="W oknie dodawania nowego sprzętu dostępna jest lista szablonów — wybranie istniejącego urządzenia z tej samej kategorii automatycznie wypełnia pola: Nazwa, Marka, Model, Numer seryjny. Można je następnie zmodyfikować."/>
                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="💡  Numer inwentarzowy generowany jest automatycznie na podstawie wybranego numeru, lokalizacji i kategorii. Podgląd aktualnego numeru widoczny jest w czasie rzeczywistym tuż pod polem numeru."/>
                        </Border>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Sprzęt bez numeru inwentarzowego"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Jeśli sprzęt ma wytarty, nieczytelny lub jeszcze nienadany numer inwentarzowy, zaznacz checkbox 'Brak nr inwentarzowego' pod polem numeru sprzętu. W takim przypadku:"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Pole numeru sprzętu zostaje zablokowane — nie można wpisać numeru"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Numer inwentarzowy nie jest generowany"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Sprzęt zostaje zapisany i widoczny jest na liście z pomarańczowym kółkiem z symbolem '?' w kolumnie Nr Inwentarzowy"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Numer można nadać później przez zdarzenie 'Nadanie nr inwentarzowego' (patrz sekcja Zdarzenia)"/>
                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="⚠️  Sprzęt bez numeru inwentarzowego jest oznaczony wizualnie na liście pomarańczowym wskaźnikiem — ułatwia to szybkie zidentyfikowanie pozycji wymagających uzupełnienia."/>
                        </Border>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- EDYCJA I USUWANIE -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_edit" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="✏️  Edycja i usuwanie"/>
                        <Separator Margin="0,0,0,10"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Aby edytować sprzęt, kliknij dwukrotnie wiersz na liście lub użyj opcji z kontekstowego menu prawego przycisku."/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Usunięcie sprzętu jest operacją trwałą — aplikacja prosi o potwierdzenie przed wykonaniem. Usunięcie sprzętu usuwa też powiązane zdarzenia z historii."/>
                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="⚠️  Zamiast trwałego usuwania rozważ zmianę statusu na Kasacja — wtedy sprzęt pozostaje w historii, ale jest wizualnie oznaczony jako wycofany."/>
                        </Border>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- NUMERY INWENTARZOWE -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_invnum" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="🔢  Numery inwentarzowe"/>
                        <Separator Margin="0,0,0,10"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Format numeru inwentarzowego zależy od kategorii sprzętu:"/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Format standardowy"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Wzór:  nr / S / kod_pawilonu / kod_kategorii"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Przykład:  12/S/86/K  (komputer nr 12, pawilon 86)"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Dotyczy wszystkich kategorii oprócz Laptopów"/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Format dla Laptopów (LAP)"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Wzór:  nr / kod_kraju / kod_pawilonu"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Przykład:  1/PL/ZM  (laptop nr 1, Polska, pawilon Zamość)"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Kod kraju i kod pawilonu (skrót) pobierane są z ustawień lokalizacji"/>

                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="💡  Kod pawilonu (skrót, np. ZM, KR) ustawia się w Narzędzia → Zarządzaj pawilonami → Edytuj wybrany pawilon. Pole &quot;Kod pawilonu&quot; służy wyłącznie do tworzenia numeru inwentarzowego laptopa."/>
                        </Border>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Sprzęt bez numeru — oznaczenie wizualne"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="W kolumnie Nr Inwentarzowy w widoku sprzętu, pozycje bez nadanego numeru wyróżnione są pomarańczowym kółkiem z symbolem '?' oraz kursywą 'brak nr'. Najechanie kursorem wyświetla tooltip wyjaśniający sytuację."/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Numer można nadać w dowolnym momencie przez zdarzenie 'Nadanie nr inwentarzowego'. Po nadaniu numeru oznaczenie znika, a sprzęt otrzymuje pełny numer inwentarzowy."/>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- KOLORY I STATUSY -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_colors" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="🎨  Kolory i statusy"/>
                        <Separator Margin="0,0,0,10"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Wiersze w tabeli sprzętu są kolorowane wg statusu i działu. Status ma priorytet nad działem:"/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Kolory statusów (wyższy priorytet)"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Zielony  —  Sprawny (status domyślny, brak kolorowania tła)"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Niebieski jasny  —  W konserwacji"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Żółty  —  Zepsuty / uszkodzony"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Czerwony jasny  —  Kasacja / zutylizowany"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Szary  —  W rezerwie (status)"/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Kolory działu (niższy priorytet)"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Fioletowy jasny  —  Dział Rezerwa (REZ) — tylko gdy status Sprawny"/>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- FILTRY I EKSPORT PDF -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_filters" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="🔎  Filtry i eksport PDF"/>
                        <Separator Margin="0,0,0,10"/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Filtry wielokrotnego wyboru"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="W widoku sprzętu nad listą znajduje się pasek filtrów (żółte tło). Umożliwia zawężenie listy do wybranych działów, statusów i/lub kategorii sprzętu, z możliwością zaznaczenia wielu opcji jednocześnie."/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Kliknij przycisk Dział ▾, Status ▾ lub Kategoria ▾ aby otworzyć listę opcji"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Zaznacz dowolną liczbę checkboxów — lista filtruje się natychmiast"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Przycisk zmienia się na np. Działów: 3 lub Kategorii: 2 gdy filtry są aktywne"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Przycisk ✕ Wyczyść filtry usuwa wszystkie zaznaczenia"/>
                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="💡  Stan filtrów (które działy, statusy i kategorie są zaznaczone) jest automatycznie zapisywany i przywracany przy kolejnym uruchomieniu aplikacji."/>
                        </Border>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Eksport do PDF"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Przycisk 📄 Eksport PDF (w pasku narzędzi widoku sprzętu) generuje raport PDF zawierający dokładnie te same pozycje, które są aktualnie widoczne na liście (z uwzględnieniem filtrów działu, statusu i wyszukiwarki)."/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Format: A4, orientacja pozioma (landscape)"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Tytuł raportu zawiera nazwę lokalizacji (jeśli przeglądasz konkretny pawilon)"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Kategorie wyświetlane są jako belki rozdzielające — nie jako osobna kolumna"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Kolumna Dział znika z wydruku, gdy aktywny jest filtr po dziale"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Kolumna Status znika z wydruku, gdy aktywny jest filtr po statusie"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Stopka zawiera numer strony i datę wygenerowania raportu"/>
                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="💡  Ustaw filtry przed kliknięciem Eksport PDF, aby wydruk zawierał tylko interesujący Cię podzbiór sprzętu — np. tylko uszkodzony sprzęt z wybranego działu."/>
                        </Border>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- WYSZUKIWANIE -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_search" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="🔍  Wyszukiwanie"/>
                        <Separator Margin="0,0,0,10"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Pole wyszukiwania znajduje się na pasku narzędzi. Wyszukiwanie działa po: numerze inwentarzowym, nazwie, marce, modelu, adresie IP oraz wartości pola Nr Seryjny / Procesor / Przekątna / Nr unikatowy (w zależności od kategorii)."/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Wpisz tekst i naciśnij Enter lub przycisk 🔍"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Przycisk ✖ czyści wyszukiwanie i przywraca pełną listę"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Wyszukiwanie nie uwzględnia wielkości liter"/>
                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="💡  Filtr kraju (zakładki na górze) i wyszukiwarka działają jednocześnie — możesz zawęzić wyniki do konkretnego kraju i słowa kluczowego naraz."/>
                        </Border>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- ZDARZENIA -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_events" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="📋  Zdarzenia"/>
                        <Separator Margin="0,0,0,10"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Widok Zdarzeń (menu Widok → Zdarzenia lub pasek narzędzi) prezentuje historię wszystkich operacji na sprzęcie, pogrupowaną wg pawilonu."/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Typy zdarzeń"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Zakup  —  rejestracja nowego sprzętu"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Serwis  —  przekazanie do serwisu i powrót"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Przeniesienie  —  zmiana lokalizacji lub działu"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Kasacja  —  wycofanie sprzętu z użytku"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Zmiana statusu  —  aktualizuje status sprzętu w bazie"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Zmiana działu  —  aktualizuje dział przypisany do sprzętu"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Zmiana nr inwentarzowego  —  aktualizuje numer inwentarzowy sprzętu"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Zmiana adresu IP  —  aktualizuje adres IP w karcie sprzętu"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Zmiana nr unikatowego kasy fiskalnej  —  aktualizuje nr unikatowy w karcie kasy fiskalnej"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Nadanie nr inwentarzowego  —  przypisuje numer do sprzętu bez numeru (patrz niżej)"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Inne  —  dowolna notatka zdarzenia"/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Nadanie nr inwentarzowego"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="To specjalny typ zdarzenia przeznaczony wyłącznie do przypisania numeru inwentarzowego sprzętowi, który nie posiada jeszcze numeru (zaznaczony opcją 'Brak nr inwentarzowego' przy dodawaniu)."/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• W oknie zdarzenia wybierz typ 'Nadanie nr inwentarzowego'"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Lista sprzętu zawęża się automatycznie tylko do pozycji bez numeru"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Po wybraniu sprzętu i wpisaniu numeru porządkowego — numer inwentarzowy jest generowany automatycznie wg formatu właściwego dla kategorii i pawilonu"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Po zapisaniu zdarzenia sprzęt otrzymuje numer inwentarzowy, a oznaczenie '?' znika z listy"/>
                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="💡  Zdarzenie 'Nadanie nr inwentarzowego' jest niedostępne dla sprzętu, który już posiada numer inwentarzowy — pojawi się ono na liście tylko wtedy, gdy w systemie istnieje co najmniej jeden sprzęt bez numeru."/>
                        </Border>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Sekcje aktywne / archiwalne"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="W ka&#x17C;dym pawilonie zdarzenia podzielone s&#x105; na sekcj&#x119; aktywnych i archiwalnych. Klikni&#x119;cie w belk&#x119; nag&#x142;&#xF3;wkow&#x105; (zielon&#x105; lub szar&#x105;) zwija lub rozwija ca&#x142;&#x105; sekcj&#x119;. Przyciski &#x229F;/&#x229E; wewn&#x105;trz belki steruj&#x105; grupami zdarze&#x144; w tej sekcji."/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Ka&#x17C;da sekcja ma w&#x142;asny, niezale&#x17C;ny pasek przewijania — mo&#x17C;na jednocze&#x15B;nie przegl&#x105;da&#x107; aktywne i archiwalne zdarzenia bez wzajemnych zak&#x142;&#xF3;ce&#x144;"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Zwinięcie sekcji przez kliknięcie w nagłówek zwalnia całą przestrzeń ekranu dla drugiej sekcji"/>
                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="💡  Skrót klawiszowy A na zaznaczonym zdarzeniu aktywnym przenosi je do archiwum bez otwierania okna edycji."/>
                        </Border>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Filtrowanie po sprzęcie"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="W widoku głównym — klikając prawym przyciskiem na wybrany sprzęt i wybierając Pokaż zdarzenia — można otworzyć widok Zdarzeń od razu przefiltrowany do historii tego urządzenia."/>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- ZAŁĄCZNIKI -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_attachments" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="📎  Załączniki do zdarzeń"/>
                        <Separator Margin="0,0,0,10"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Do każdego zdarzenia (nowego i istniejącego) można podpiąć pliki w formatach: JPG, PNG, PDF, WEBP. Załączniki przechowywane są w wybranym przez użytkownika folderze na dysku."/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Sposoby dodawania załączników"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• W oknie dodawania / edycji zdarzenia — sekcja Załączniki na dole formularza"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Menu kontekstowe (PPM na zdarzeniu) → Dodaj załącznik"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Skrót Ctrl+Z na zaznaczonym zdarzeniu — otwiera okno wyboru pliku"/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Przeglądanie załączników"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Menu kontekstowe (PPM na zdarzeniu) → Pokaż załączniki [Z]"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Klawisz Z na zaznaczonym zdarzeniu — otwiera okno z listą załączników"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• W oknie załączników: dwuklik lub przycisk Otwórz otwiera plik w domyślnej aplikacji"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Zdarzenia posiadające załączniki oznaczone są ikoną 📎 w pierwszej kolumnie widoku"/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Folder przechowywania"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Przy pierwszym dodaniu załącznika aplikacja pyta o folder docelowy. Wybrany folder zapisywany jest w preferencjach. Można go zmienić w oknie załączników przyciskiem Zmień folder."/>

                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="💡  Zdarzenia z załącznikami widać na pierwszy rzut oka — ikona 📎 pojawia się w pierwszej kolumnie tabeli zdarzeń (aktywnych i archiwalnych)."/>
                        </Border>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- PAWILONY -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_locations" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="🏪  Pawilony (lokalizacje)"/>
                        <Separator Margin="0,0,0,10"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Pawilony to lokalizacje fizyczne sklepów. Każdy pawilon ma:"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Kod numeryczny (np. 86) — używany w standardowym formacie numeru inwentarzowego"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Krótki kod pawilonu (np. ZM) — używany w numerze inwentarzowym Laptopów"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Kod kraju (np. PL) — wyświetlany jako zakładka filtrowania w widoku sprzętu"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Nazwa, adres, miasto — dane opisowe"/>
                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="💡  Pawilonowi można ustawić flagę &quot;Nieaktywny&quot; — sprzęt z nieaktywnego pawilonu nadal widoczny jest na liście, ale pawilon nie pojawia się w zakładkach zdarzeń."/>
                        </Border>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- KATEGORIE I DZIAŁY -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_categories" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="📂  Kategorie i działy"/>
                        <Separator Margin="0,0,0,10"/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Kategorie"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Kategorie służą do grupowania sprzętu wg jego typu (Komputery, Monitory, Drukarki…). Kolejność wyświetlania w widoku sprzętu określa pole SortOrder — niższy numer = wyżej na liście. Kategoria Laptopy (LAP) wyświetlana jest zawsze na końcu."/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Działy"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Dział to miejsce w sklepie, do którego przypisany jest dany sprzęt (np. AGD, Kasa, Kierownik). W oknie dodawania i edycji sprzętu pierwsza pozycja na liście działów to &quot;N/A (brak działu)&quot; — wybranie jej oznacza, że sprzęt nie jest przypisany do żadnego działu. Dział REZ (Rezerwa) oznaczony jest fioletowym kolorem tła wiersza."/>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- POWIADOMIENIA -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_alerts" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="🔔  Powiadomienia"/>
                        <Separator Margin="0,0,0,10"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="System powiadomień pozwala ustawić alerty z datą wyzwolenia — np. przypomnienie o legalizacji wagi w lipcu 2027 lub przeglądzie drukarek fiskalnych. Każde powiadomienie można przypisać do konkretnego sprzętu, całej kategorii lub oznaczyć jako ogólne."/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Dodawanie powiadomienia"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Widok Powiadomienia → przycisk Dodaj powiadomienie w toolbarze"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Wypełnij: Zakres (sprzęt / kategoria / ogólne), Nazwę, Datę wyzwolenia i Treść"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Data wyzwolenia — od tej daty powiadomienie jest traktowane jako aktywne (wyzwolone)"/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Sygnalizacja aktywnych powiadomień"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Pomarańczowy baner pod paskiem narzędzi — widoczny na każdym widoku gdy są wyzwolone alerty; kliknięcie otwiera widok Powiadomień"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Czerwony licznik na przycisku 🔔 Powiadomienia w pasku narzędzi"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Okno startowe przy uruchomieniu — lista aktywnych alertów wyświetlana automatycznie (można wyłączyć na dziś)"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Ikona w zasobniku systemowym (tray) — zmienia się na czerwoną gdy są aktywne powiadomienia"/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Widok Powiadomień"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Aktywne alerty: żółte wiersze = powiadomienia których data wyzwolenia już minęła"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Kolumny: Status, Nazwa, Dotyczy, Data wyzwolenia, Treść, Opis"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Toolbar: Dodaj / Edytuj / Archiwizuj / Usuń"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Archiwum zdarzeń — rozwijany panel na dole widoku z historią zarchiwizowanych alertów"/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Zasobnik systemowy (tray)"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Po zminimalizowaniu okna aplikacja znika z paska zadań i działa w tle jako ikona dzwonka w zasobniku systemowym. Aby przywrócić okno: dwuklik na ikonę lub menu kontekstowe → Pokaż okno. Menu traya zawiera także opcję Wyjście."/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Autostart przy starcie systemu"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Aplikację można skonfigurować tak, aby uruchamiała się automatycznie po zalogowaniu do Windows. Opcja dostępna jest w menu Narzędzia → Konfiguracja (ikona ⚙️)."/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Zaznacz opcję 'Uruchamiaj aplikację przy starcie systemu Windows' i kliknij OK"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Aplikacja zostanie automatycznie uruchomiona przy następnym logowaniu — zminimalizowana do traya"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Wpis tworzony jest w rejestrze HKCU (dla bieżącego użytkownika) — nie wymaga uprawnień administratora"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Odznaczenie opcji i kliknięcie OK usuwa wpis autostartu z rejestru"/>

                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="💡  Powiadomienia są odświeżane automatycznie co 30 minut — nie musisz restartować aplikacji aby zobaczyć nowe alerty."/>
                        </Border>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- EKSPORT / IMPORT CSV -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_csv" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="📊  Eksport / Import CSV"/>
                        <Separator Margin="0,0,0,10"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Aplikacja umożliwia wymianę danych sprzętowych z zewnętrznymi arkuszami kalkulacyjnymi przez pliki CSV."/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Eksport do CSV"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Menu Plik → Eksport do CSV"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Eksportuje aktualnie przefiltrowaną listę sprzętu (uwzględnia filtry działu, statusu, kategorii i wyszukiwania)"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Format: separator ; (średnik), kodowanie UTF-8 z BOM — kompatybilny z polską wersją Excel"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Daty w formacie yyyy-MM-dd, ceny z kropką dziesiętną"/>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Import z CSV"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Menu Plik → Import z CSV"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Po wybraniu pliku wyświetlane jest podsumowanie: ile rekordów zaimportowano, ile pominięto z błędami"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Wymagane kolumny: Nazwa, Kategoria; pozostałe są opcjonalne"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Kategorie i lokalizacje muszą istnieć w aplikacji — niezgodne wartości są pomijane z komunikatem"/>

                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="💡  Aby uzyskać poprawny szablon CSV do importu, wykonaj najpierw eksport istniejącego sprzętu — plik wynikowy pokazuje prawidłową strukturę kolumn."/>
                        </Border>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- KOPIA ZAPASOWA -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <StackPanel x:Name="sec_backup" Margin="0,0,0,28">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="💾  Kopia zapasowa"/>
                        <Separator Margin="0,0,0,10"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Baza danych przechowywana jest w jednym pliku SQLite. Eksport i import dostępne są w menu Narzędzia:"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Narzędzia → Eksportuj bazę danych… — zapisuje kopię pliku inventory.db w wybranym miejscu"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Narzędzia → Importuj bazę danych… — zastępuje bieżącą bazę wybranym plikiem (wymaga restartu)"/>
                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="⚠️  Import bazy danych nadpisuje wszystkie bieżące dane. Przed importem zawsze wykonaj eksport aktualnej bazy jako zabezpieczenie."/>
                        </Border>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Kopia zapasowa załączników"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Załączniki przechowywane są poza bazą danych, w osobnym folderze. Dostępne opcje:"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Narzędzia → Eksportuj załączniki jako ZIP… — pakuje wszystkie pliki do archiwum ZIP z manifestem ścieżki"/>
                        <TextBlock Style="{StaticResource BulletStyle}" Text="• Narzędzia → Importuj załączniki z ZIP… — ekstrahuje pliki; pyta o oryginalną ścieżkę lub pozwala wskazać nową"/>
                        <Border Style="{StaticResource TipStyle}">
                            <TextBlock Style="{StaticResource ParaStyle}" Margin="0"
                                Text="💡  Przy przenoszeniu na inny komputer: zrób eksport bazy (inventory.db) ORAZ eksport załączników (ZIP). Na nowym komputerze: importuj bazę, następnie importuj załączniki — aplikacja może zaktualizować folder automatycznie."/>
                        </Border>

                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Lokalizacja bazy danych"/>
                        <TextBlock Style="{StaticResource ParaStyle}"
                            Text="Plik bazy danych (inventory.db) przechowywany jest w folderze danych aplikacji:"/>
                        <TextBlock Style="{StaticResource BulletStyle}"
                            Text="• %APPDATA%\InwentaryzacjaSprzetu\inventory.db"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Stopka -->
            <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#DDDDDD"
                    BorderThickness="0,1,0,0" Padding="16,8">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Zamknij" Width="90" Height="28"
                            Click="CloseButton_Click" IsDefault="True"/>
                    <TextBlock Text="Inwentaryzacja Sprzętu — Merkury Market"
                               Foreground="#888" FontSize="11"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
