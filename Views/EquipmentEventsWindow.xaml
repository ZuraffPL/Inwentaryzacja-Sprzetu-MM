<Window x:Class="InwentaryzacjaSprzetu.Views.EquipmentEventsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:InwentaryzacjaSprzetu.Helpers"
        Title="Zdarzenia sprzętu"
        Width="1100" Height="650"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <helpers:EnumToStringConverter x:Key="EnumToStringConverter"/>
        <helpers:EventStatusToForegroundConverter x:Key="EventStatusToForegroundConverter"/>
        <helpers:EventTypeToPastelBackgroundConverter x:Key="EventTypeToPastelBackgroundConverter"/>

        <Style x:Key="EventRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#5B9BD5"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek z informacjami o sprzęcie -->
        <Border Grid.Row="0" Background="#E8E8E8" Padding="14,10">
            <StackPanel>
                <TextBlock x:Name="TitleText" FontSize="17" FontWeight="Bold" Foreground="#222"/>
                <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="#666" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- DataGrid ze zdarzeniami -->
        <DataGrid Grid.Row="1"
                  x:Name="EventsDataGrid"
                  ItemsSource="{Binding Events}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  AlternationCount="2"
                  RowStyle="{StaticResource EventRowStyle}"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  Margin="0">

            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#5B9BD5"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <!-- Data zdarzenia -->
                <DataGridTextColumn Header="Data" Width="100"
                                    Binding="{Binding EventDate, StringFormat='{}{0:dd.MM.yyyy}'}"
                                    SortMemberPath="EventDate"/>

                <!-- Typ zdarzenia -->
                <DataGridTextColumn Header="Typ zdarzenia" Width="160"
                                    Binding="{Binding EventType, Converter={StaticResource EnumToStringConverter}}"
                                    SortMemberPath="EventType"/>

                <!-- Status (Aktywne / Archiwum) -->
                <DataGridTemplateColumn Header="Status" Width="110" SortMemberPath="EventStatus">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding EventStatus, Converter={StaticResource EnumToStringConverter}}"
                                       Foreground="{Binding EventStatus, Converter={StaticResource EventStatusToForegroundConverter}}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Opis zdarzenia -->
                <DataGridTextColumn Header="Opis" Width="*"
                                    Binding="{Binding Description}"/>

                <!-- Zmiana (poprzedni → nowy status) -->
                <DataGridTextColumn Header="Zmiana statusu" Width="160"
                                    Binding="{Binding ChangeSummary}"/>

                <!-- Lokalizacja -->
                <DataGridTextColumn Header="Lokalizacja" Width="130"
                                    Binding="{Binding Location.Name}"/>

                <!-- Wykonane przez -->
                <DataGridTextColumn Header="Wykonane przez" Width="130"
                                    Binding="{Binding PerformedBy}"/>

                <!-- Uwagi -->
                <DataGridTextColumn Header="Uwagi" Width="150"
                                    Binding="{Binding Notes}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Dolny pasek ze statusem i przyciskiem zamknięcia -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="10,8" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Zamknij" Padding="20,5"
                        IsDefault="True" IsCancel="True"
                        Click="CloseButton_Click"/>
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="#555" FontSize="12"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
