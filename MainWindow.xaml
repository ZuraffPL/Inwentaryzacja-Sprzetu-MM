<Window x:Class="InwentaryzacjaSprzetu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:InwentaryzacjaSprzetu.Views"
        xmlns:helpers="clr-namespace:InwentaryzacjaSprzetu.Helpers"
        mc:Ignorable="d"
        Title="Inwentaryzacja Sprzętu" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <helpers:StringToBoolConverter x:Key="StringToBoolConverter"/>
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <helpers:EnumToStringConverter x:Key="EnumToStringConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>  <!-- baner alertów -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu główne -->
        <Menu Grid.Row="0" Background="#F0F0F0">
            <MenuItem Header="_Plik">
                <MenuItem Header="_Nowy sprzęt" Command="{Binding AddEquipmentCommand}"/>
                <Separator/>
                <MenuItem Header="_Eksport do CSV" Command="{Binding ExportEquipmentToCsvCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="📊" FontSize="13"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Import z CSV" Command="{Binding ImportEquipmentFromCsvCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="📥" FontSize="13"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Wyjście" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_Widok">
                <MenuItem Header="_Sprzęt" Command="{Binding ShowEquipmentViewCommand}" IsChecked="{Binding CurrentView, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Equipment}"/>
                <MenuItem Header="_Kategorie" Command="{Binding ShowCategoriesViewCommand}" IsChecked="{Binding CurrentView, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Categories}"/>
                <MenuItem Header="_Pawilony" Command="{Binding ShowLocationsViewCommand}" IsChecked="{Binding CurrentView, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Locations}"/>
                <MenuItem Header="_Zdarzenia" Command="{Binding ShowEventsViewCommand}" IsChecked="{Binding CurrentView, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Events}"/>
                <MenuItem Header="🔔 Powiadomienia" Command="{Binding ShowAlertsViewCommand}" IsChecked="{Binding CurrentView, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Alerts}"/>
            </MenuItem>
            <MenuItem Header="_Narzędzia">
                <MenuItem Header="_Eksportuj bazę danych..." Command="{Binding ExportDatabaseCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="💾" FontSize="13"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Importuj bazę danych..." Command="{Binding ImportDatabaseCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="📂" FontSize="13"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Eksportuj załączniki jako ZIP..." Command="{Binding ExportAttachmentsZipCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="📦" FontSize="13"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Importuj załączniki z ZIP..." Command="{Binding ImportAttachmentsZipCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="📬" FontSize="13"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Konfiguracja"/>
            </MenuItem>
            <MenuItem Header="_Pomoc">
                <MenuItem Header="_Historia wersji" Click="ChangelogMenuItem_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="📋" FontSize="13"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Instrukcja obsługi" Click="UserManualMenuItem_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="📖" FontSize="13"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_O programie" Click="AboutMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Pasek narzędzi -->
        <ToolBar Grid.Row="1" Background="#E8E8E8">
            <Button Command="{Binding ShowEquipmentViewCommand}" ToolTip="Sprzęt">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📦" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Sprzęt"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button Command="{Binding ShowCategoriesViewCommand}" ToolTip="Kategorie">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📂" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Kategorie"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding ShowLocationsViewCommand}" ToolTip="Pawilony">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🏪" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Pawilony"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding ShowEventsViewCommand}" ToolTip="Zdarzenia">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📋" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Zdarzenia"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding ShowAlertsViewCommand}" ToolTip="Powiadomienia">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔔" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Powiadomienia"/>
                    <!-- Znaczek licznika gdy są wyzwolone alerty -->
                    <Border Background="#D32F2F" CornerRadius="8" Padding="4,0" Margin="4,0,0,0"
                            Visibility="{Binding HasTriggeredAlerts, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding TriggeredAlertCount}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Button>
            <Separator/>
            
            <!-- Wyszukiwanie -->
            <TextBlock Text="Szukaj:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3">
                <Grid>
                    <TextBox x:Name="SearchTextBox" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Width="200" Height="25" BorderThickness="0" Padding="5,2"
                             KeyDown="SearchTextBox_KeyDown"/>
                    <TextBlock Text="Wpisz tekst do wyszukania..." 
                               Foreground="#888" Margin="8,5,0,0" IsHitTestVisible="False"
                               Visibility="{Binding SearchText, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Empty}"/>
                </Grid>
            </Border>
            <Button Command="{Binding SearchCommand}" Content="🔍" ToolTip="Szukaj" 
                    Margin="2,0,0,0" Height="25" Width="30" Background="#E8E8E8"/>
            <Button Command="{Binding ClearSearchCommand}" Content="✖" ToolTip="Wyczyść wyszukiwanie" 
                    Margin="2,0,0,0" Height="25" Width="25" Background="#FFE8E8"
                    Visibility="{Binding SearchText, Converter={StaticResource StringToVisibilityConverter}}"/>
        </ToolBar>

        <!-- Baner alertów (widoczny gdy są wyzwolone) -->
        <Border Grid.Row="2" Background="#FF8C00" Padding="10,6"
                Visibility="{Binding HasTriggeredAlerts, Converter={StaticResource BoolToVis}}"
                Cursor="Hand">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding ShowAlertsViewCommand}"/>
            </Border.InputBindings>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="🔔" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding TriggeredAlertCount, StringFormat='Masz {0} aktywnych powiadomień — '}"
                           FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="kliknij, aby wyświetlić" Foreground="White" VerticalAlignment="Center"
                           TextDecorations="Underline"/>
            </StackPanel>
        </Border>

        <!-- Główna zawartość -->
        <Grid Grid.Row="3">
            <!-- Widok sprzętu -->
            <views:EquipmentView x:Name="EquipmentView" 
                                Visibility="{Binding CurrentView, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Equipment}"/>
            
            <!-- Widok kategorii -->
            <views:CategoriesView x:Name="CategoriesView" 
                                 Visibility="{Binding CurrentView, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Categories}"/>
            
            <!-- Widok lokalizacji -->
            <views:LocationsView x:Name="LocationsView" 
                                Visibility="{Binding CurrentView, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Locations}"/>
            
            <!-- Widok zdarzeń -->
            <views:EventsView x:Name="EventsView" 
                             Visibility="{Binding CurrentView, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Events}"/>
            
            <!-- Widok alertów / powiadomień -->
            <views:AlertsView x:Name="AlertsView" 
                             Visibility="{Binding CurrentView, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Alerts}"/>
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="4" Background="#F0F0F0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Sprzęt: "/>
                    <TextBlock Text="{Binding Equipment.Count}"/>
                    <TextBlock Text=" | W rezerwie: " Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding ReserveDepartmentCount}"/>
                    <TextBlock Text=" | Sprawny: " Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding StatusActiveCount}"/>
                    <TextBlock Text=" | Rezerwa (st.): " Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding StatusInactiveCount}"/>
                    <TextBlock Text=" | Konserwacja: " Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding StatusMaintenanceCount}"/>
                    <TextBlock Text=" | Zepsuty: " Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding StatusDamagedCount}"/>
                    <TextBlock Text=" | Kasacja: " Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding StatusDisposedCount}"/>
                    <TextBlock Text=" | Kategorie: " Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding Categories.Count}"/>
                    <TextBlock Text=" | Pawilony: " Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding Locations.Count}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>